---
// Standalone /bio — sem Layout/BaseHead pra controlar robots noindex e
// evitar JSON-LD de SoftwareApplication (não faz sentido aqui).
const RSS_URL = 'https://blog.pokerplaybook.pro/rss.xml';
const BLOG_FALLBACK = 'https://blog.pokerplaybook.pro/blog/';
const APP_CTA = 'https://app.pokerplaybook.pro?utm_source=instagram&utm_medium=bio&utm_campaign=app_cta';
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, follow, noarchive" />
  <title>Link na Bio · Poker Playbook</title>
  <meta name="description" content="Últimos artigos do blog — mental game, rotina e performance pra jogadores de MTT." />

  <link rel="icon" type="image/png" href="/spade-logo.png" />

  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Poker Playbook" />
  <meta property="og:title" content="Link na Bio · Poker Playbook" />
  <meta property="og:description" content="Últimos artigos do blog — mental game, rotina e performance pra jogadores de MTT." />
  <meta property="og:image" content="https://pokerplaybook.pro/og-default.png" />
  <meta property="og:url" content="https://pokerplaybook.pro/bio/" />
  <meta property="og:locale" content="pt_BR" />

  <script async src="https://www.googletagmanager.com/gtag/js?id=G-7ZRQS4R3GQ"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-7ZRQS4R3GQ');
  </script>

  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
    body {
      background: #0a0e17;
      color: #f1f5f9;
      font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      line-height: 1.5;
      min-height: 100vh;
      padding: 1.5rem 1rem 3rem;
    }
    img { max-width: 100%; display: block; }
    a { color: inherit; text-decoration: none; }

    .bio-container {
      max-width: 480px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: 1.75rem;
    }

    .bio-header { text-align: center; padding-top: 1rem; }
    .bio-logo {
      width: 56px;
      height: 56px;
      margin: 0 auto 0.75rem;
      filter: drop-shadow(0 0 12px rgba(222, 181, 113, 0.35));
    }
    .bio-brand {
      font-size: 1.35rem;
      font-weight: 700;
      color: #DEB571;
      letter-spacing: -0.01em;
    }
    .bio-tagline {
      margin-top: 0.35rem;
      font-size: 0.95rem;
      color: #94a3b8;
    }

    .bio-section-title {
      font-size: 0.85rem;
      font-weight: 600;
      color: #cbd5e1;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 0.85rem;
    }

    .bio-posts { display: flex; flex-direction: column; gap: 0.85rem; }

    .bio-card {
      background: #1e293b;
      border: 1px solid #334155;
      border-radius: 14px;
      padding: 1rem 1.1rem 1.15rem;
      transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
      display: block;
    }
    .bio-card:hover {
      transform: translateY(-2px);
      border-color: #DEB571;
      box-shadow: 0 8px 24px rgba(222, 181, 113, 0.12);
    }
    .bio-card-date {
      display: inline-block;
      font-size: 0.72rem;
      font-weight: 700;
      color: #DEB571;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-bottom: 0.45rem;
    }
    .bio-card-title {
      font-size: 1.05rem;
      font-weight: 600;
      color: #f1f5f9;
      line-height: 1.35;
      margin-bottom: 0.5rem;
    }
    .bio-card-snippet {
      font-size: 0.88rem;
      color: #94a3b8;
      line-height: 1.5;
      margin-bottom: 0.6rem;
    }
    .bio-card-cta {
      font-size: 0.82rem;
      font-weight: 600;
      color: #DEB571;
    }

    .bio-skeleton {
      background: #1e293b;
      border: 1px solid #334155;
      border-radius: 14px;
      padding: 1rem 1.1rem 1.15rem;
    }
    .bio-skeleton-line {
      height: 0.9rem;
      background: linear-gradient(90deg, #1e293b 0%, #2a3a52 50%, #1e293b 100%);
      background-size: 200% 100%;
      animation: shimmer 1.6s infinite;
      border-radius: 4px;
      margin-bottom: 0.55rem;
    }
    .bio-skeleton-line.short { width: 30%; }
    .bio-skeleton-line.long { width: 95%; }
    .bio-skeleton-line.medium { width: 70%; }
    .bio-skeleton-line:last-child { margin-bottom: 0; width: 25%; }
    @keyframes shimmer {
      0% { background-position: 200% 0; }
      100% { background-position: -200% 0; }
    }

    .bio-empty {
      background: #1e293b;
      border: 1px solid #334155;
      border-radius: 14px;
      padding: 1.25rem 1rem;
      text-align: center;
      color: #cbd5e1;
      font-size: 0.95rem;
    }
    .bio-empty a { color: #DEB571; font-weight: 600; }

    .bio-links { display: flex; flex-direction: column; gap: 0.65rem; }
    .bio-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      padding: 0.95rem 1rem;
      background: #1e293b;
      border: 1px solid #334155;
      border-radius: 12px;
      font-size: 0.95rem;
      font-weight: 600;
      color: #f1f5f9;
      transition: border-color 0.2s ease, transform 0.2s ease, background 0.2s ease;
    }
    .bio-btn:hover {
      border-color: #DEB571;
      transform: translateY(-1px);
    }
    .bio-btn-primary {
      background: #DEB571;
      color: #0a0e17;
      border-color: #DEB571;
    }
    .bio-btn-primary:hover {
      background: #e6c489;
      border-color: #e6c489;
    }

    @media (min-width: 520px) {
      body { padding: 2.5rem 1.25rem 4rem; }
      .bio-logo { width: 64px; height: 64px; }
      .bio-brand { font-size: 1.5rem; }
    }
  </style>
</head>
<body>
  <main class="bio-container">
    <header class="bio-header">
      <img src="/spade-logo.png" alt="Poker Playbook" width="64" height="64" class="bio-logo" />
      <div class="bio-brand">Poker Playbook</div>
      <p class="bio-tagline">A mente por trás do grind</p>
    </header>

    <section aria-labelledby="posts-title">
      <h2 id="posts-title" class="bio-section-title">Últimos artigos</h2>
      <div id="bio-posts" class="bio-posts">
        <div class="bio-skeleton"><div class="bio-skeleton-line short"></div><div class="bio-skeleton-line long"></div><div class="bio-skeleton-line medium"></div><div class="bio-skeleton-line"></div></div>
        <div class="bio-skeleton"><div class="bio-skeleton-line short"></div><div class="bio-skeleton-line long"></div><div class="bio-skeleton-line medium"></div><div class="bio-skeleton-line"></div></div>
        <div class="bio-skeleton"><div class="bio-skeleton-line short"></div><div class="bio-skeleton-line long"></div><div class="bio-skeleton-line medium"></div><div class="bio-skeleton-line"></div></div>
      </div>
    </section>

    <section class="bio-links">
      <a class="bio-btn bio-btn-primary" href={APP_CTA}>🎯 Começar grátis</a>
      <a class="bio-btn" href={BLOG_FALLBACK}>📝 Blog completo</a>
      <a class="bio-btn" href="/en/bio/">🌐 English version</a>
    </section>
  </main>

  <script is:inline define:vars={{ RSS_URL, BLOG_FALLBACK }}>
    (function () {
      const container = document.getElementById('bio-posts');
      if (!container) return;

      const MONTHS_PT = ['jan','fev','mar','abr','mai','jun','jul','ago','set','out','nov','dez'];

      function humanizeDate(d) {
        const now = new Date();
        const nowUtc = Date.UTC(now.getUTCFullYear(), now.getUTCMonth(), now.getUTCDate());
        const postUtc = Date.UTC(d.getUTCFullYear(), d.getUTCMonth(), d.getUTCDate());
        const dayDiff = Math.floor((nowUtc - postUtc) / 86400000);

        if (dayDiff <= 0) return 'Hoje';
        if (dayDiff === 1) return 'Ontem';
        if (dayDiff < 7) return 'há ' + dayDiff + ' dias';
        return d.getUTCDate() + ' ' + MONTHS_PT[d.getUTCMonth()];
      }

      function truncate(s, n) {
        if (!s) return '';
        const trimmed = s.trim();
        if (trimmed.length <= n) return trimmed;
        const cut = trimmed.substring(0, n);
        const lastSpace = cut.lastIndexOf(' ');
        return (lastSpace > n - 30 ? cut.substring(0, lastSpace) : cut) + '…';
      }

      function slugFromLink(href) {
        try {
          const u = new URL(href);
          const parts = u.pathname.split('/').filter(Boolean);
          return parts[parts.length - 1] || '';
        } catch (e) {
          return '';
        }
      }

      function renderEmpty() {
        container.innerHTML = '';
        const empty = document.createElement('div');
        empty.className = 'bio-empty';
        const link = document.createElement('a');
        link.href = BLOG_FALLBACK;
        link.textContent = 'Veja todos os artigos no blog →';
        empty.appendChild(link);
        container.appendChild(empty);
      }

      function buildCard(item) {
        const titleEl = item.querySelector('title');
        const linkEl = item.querySelector('link');
        const descEl = item.querySelector('description');
        const pubDateEl = item.querySelector('pubDate');

        const title = titleEl ? titleEl.textContent.trim() : '';
        const href = linkEl ? linkEl.textContent.trim() : '';
        const desc = descEl ? descEl.textContent.trim() : '';
        const pubDate = pubDateEl ? new Date(pubDateEl.textContent.trim()) : null;

        if (!title || !href || !pubDate || isNaN(pubDate.getTime())) return null;
        if (!/^https:\/\//.test(href)) return null;

        const slug = slugFromLink(href);
        const utmHref = href + (href.indexOf('?') === -1 ? '?' : '&')
          + 'utm_source=instagram&utm_medium=bio&utm_campaign=' + encodeURIComponent(slug);

        const card = document.createElement('a');
        card.className = 'bio-card';
        card.href = utmHref;
        card.rel = 'noopener';

        const dateEl = document.createElement('div');
        dateEl.className = 'bio-card-date';
        dateEl.textContent = humanizeDate(pubDate);

        const titleNode = document.createElement('div');
        titleNode.className = 'bio-card-title';
        titleNode.textContent = title;

        const snippet = document.createElement('div');
        snippet.className = 'bio-card-snippet';
        snippet.textContent = truncate(desc, 140);

        const cta = document.createElement('div');
        cta.className = 'bio-card-cta';
        cta.textContent = 'Ler artigo →';

        card.appendChild(dateEl);
        card.appendChild(titleNode);
        if (snippet.textContent) card.appendChild(snippet);
        card.appendChild(cta);
        return card;
      }

      async function load() {
        try {
          const resp = await fetch(RSS_URL, { cache: 'no-store' });
          if (!resp.ok) { renderEmpty(); return; }
          const text = await resp.text();
          const doc = new DOMParser().parseFromString(text, 'application/xml');
          const parseErr = doc.querySelector('parsererror');
          if (parseErr) { renderEmpty(); return; }

          const items = Array.from(doc.querySelectorAll('item')).slice(0, 3);
          if (items.length === 0) { renderEmpty(); return; }

          const cards = items.map(buildCard).filter(Boolean);
          if (cards.length === 0) { renderEmpty(); return; }

          container.innerHTML = '';
          cards.forEach(c => container.appendChild(c));
        } catch (e) {
          renderEmpty();
        }
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', load);
      } else {
        load();
      }
    })();
  </script>
</body>
</html>
