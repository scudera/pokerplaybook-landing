---
import Layout from '../../layouts/Layout.astro';

const title = 'Poker Playbook — Mental Performance for MTT Players';
const description = 'The first AI-powered mental performance platform for poker. Control tilt, build routine and make better decisions. Free to start.';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is Poker Playbook?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A complete performance system for professional poker players. Combines daily check-in, AI Coach with Claude Opus 4, Mastery system with XP, and detailed analytics of the 4 Pillars (Body, Mind, Craft, System).'
      }
    },
    {
      '@type': 'Question',
      name: 'Is the app free?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The Grind plan is 100% free — no trial period, no credit card required. It includes daily check-in, score, routine, mindset and records. For AI Coach, advanced analytics and custom checklist, there are Pro and Elite plans. All paid plans have a 25% discount on the annual plan.'
      }
    },
    {
      '@type': 'Question',
      name: 'How does the AI Coach work?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "The AI Coach is powered by Claude Opus (Anthropic's frontier AI) and analyzes your check-in data — tournament volume, exercise, sleep, study, feelings during the grind. It generates 5 report types (weekly, monthly, yearly, complete and emotional patterns) using frameworks from Jared Tendler, Tommy Angelo, sports periodization and deliberate practice."
      }
    },
    {
      '@type': 'Question',
      name: 'What are the 4 Pillars?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The 4 dimensions of professional poker performance: Body (exercise, sleep, breathing), Mind (gratitude, emotional awareness), Craft (grind volume and study hours) and System (consistency and perfect days). Each pillar gets a 0-10 score in your weekly report.'
      }
    },
    {
      '@type': 'Question',
      name: 'What is the Scientist Agent?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'An exclusive Elite plan feature that analyzes your data and proposes hypotheses about what improves your performance. You approve the hypotheses, the agent tests with your real data, and confirmed knowledge feeds your future analyses.'
      }
    },
    {
      '@type': 'Question',
      name: 'Does it work for cash games?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Poker Playbook was built for MTT. Metrics, goals and AI Coach analyses are calibrated for tournaments — tournament volume, buy-in, field, ITM. The mental performance tools (routine, mindset, breathing) work for any format, but the full experience is optimized for MTT grinders.'
      }
    },
    {
      '@type': 'Question',
      name: 'Does this actually work?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "We won't promise your ROI will go up. Poker has variance and results depend on many factors. What the Playbook gives you is a system, data and insights to build a solid mental foundation. The impact on results is a consequence of playing with better preparation — consistently, not by luck."
      }
    },
    {
      '@type': 'Question',
      name: 'Is my data private?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Your data stays in your profile and only you have access. The AI Coach processes your data exclusively to generate your personal analyses. No information is shared with third parties or used to train AI models.'
      }
    },
    {
      '@type': 'Question',
      name: 'Can I use it on mobile?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Poker Playbook is a responsive web app optimized for any browser — desktop, tablet or mobile. No app download needed. Just go to app.pokerplaybook.pro and sign in.'
      }
    },
    {
      '@type': 'Question',
      name: 'Do I need experience to use it?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No. The onboarding sets everything up in 5 simple steps: your goals, weekly schedule, routine, and objectives. The app guides you daily with check-in, checklist, and gratitudes.'
      }
    },
    {
      '@type': 'Question',
      name: 'Can I cancel anytime?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Cancellation is instant via the Stripe payment portal. No penalty, no commitment, no hassle. Your plan stays active until the end of the paid period.'
      }
    }
  ]
};
---

<Layout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- ========== NAV ========== -->
  <nav class="nav" id="navbar">
    <div class="container nav-inner">
      <a href="/en/" class="nav-logo">
        <span class="spade">♠</span> Poker Playbook
      </a>
      <ul class="nav-links" id="nav-links">
        <li><a href="#problem">The Problem</a></li>
        <li><a href="#pillars">4 Pillars</a></li>
        <li><a href="#coach">AI Coach</a></li>
        <li><a href="#how-it-works">How It Works</a></li>
        <li><a href="#pricing">Plans</a></li>
        <li><a href="https://blog.pokerplaybook.pro" target="_blank">Blog</a></li>
        <li><a href="/" class="lang-switch" title="Português">PT</a></li>
        <li><a href="https://app.pokerplaybook.pro" class="nav-cta">Open App →</a></li>
      </ul>
      <button class="nav-mobile-toggle" id="nav-toggle" aria-label="Menu">☰</button>
    </div>
  </nav>

  <!-- ========== HERO ========== -->
  <section class="hero section" id="hero">
    <div class="container">
      <div class="hero-content">
        <div class="hero-badge">
          ♠ Start free — plans from R$29/month
        </div>

        <h1>
          You know how to play. But do you know <span class="gradient">how to prepare?</span>
        </h1>

        <p class="hero-sub">
          Solvers don't fix tilt. Trackers don't measure sleep. Coaches aren't there every day. Poker Playbook is the first AI-powered mental performance platform, built by someone who lives MTT.
        </p>

        <div class="hero-actions">
          <a href="https://app.pokerplaybook.pro" class="btn-primary">
            Start free →
          </a>
          <a href="#how-it-works" class="btn-secondary">
            How it works
          </a>
        </div>

        <div class="hero-proof">
          <div class="hero-proof-item">
            <span class="icon">✓</span> Free Grind plan
          </div>
          <div class="hero-proof-item">
            <span class="icon">✓</span> No credit card
          </div>
          <div class="hero-proof-item">
            <span class="icon">✓</span> 2-minute setup
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== THE PROBLEM ========== -->
  <section class="section" id="problem" style="background: var(--bg-secondary);">
    <div class="container">
      <div class="animate-on-scroll" style="text-align: center;">
        <span class="section-label" style="justify-content: center;">The problem</span>
        <h2 class="section-title">The market gave you everything. Except this.</h2>
        <p class="section-subtitle" style="margin: 0 auto;">
          There are solvers for every spot. Trackers for every session. Coaches for every leak. But for the mental side — what actually separates those who move up from those who stay stuck — there's no tool. No method to track. No data to measure. No system to evaluate. Just willpower — and willpower doesn't scale.
        </p>
      </div>
    </div>
  </section>

  <!-- ========== 4 PILLARS ========== -->
  <section class="section" id="pillars">
    <div class="container">
      <div class="animate-on-scroll">
        <span class="section-label">The 4 Pillars</span>
        <h2 class="section-title">4 dimensions. 1 system.</h2>
        <p class="section-subtitle">
          You already know tilt costs buy-ins and bad sleep kills decisions. Poker Playbook turns that into data and routine.
        </p>
      </div>

      <div class="pillars-grid">
        <a href="/en/body/" class="pillar-card animate-on-scroll" data-pillar="corpo">
          <div class="pillar-icon">💪</div>
          <h3>Body <span style="font-size:0.75rem;color:var(--text-muted);">→</span></h3>
          <p>Sleep, exercise, wake time and breathing. When the body fails, your A-game disappears. The app tracks this daily — so you stop guessing and start knowing.</p>
          <div class="pillar-metrics">
            <span class="pillar-metric">Exercise</span>
            <span class="pillar-metric">Sleep</span>
            <span class="pillar-metric">Wake-up</span>
            <span class="pillar-metric">Breathing</span>
          </div>
        </a>

        <a href="/en/mind/" class="pillar-card animate-on-scroll" data-pillar="mente">
          <div class="pillar-icon">🧠</div>
          <h3>Mind <span style="font-size:0.75rem;color:var(--text-muted);">→</span></h3>
          <p>Gratitude, emotional awareness, tilt control. It's not about "being positive" — it's about identifying patterns before they cost you money.</p>
          <div class="pillar-metrics">
            <span class="pillar-metric">Gratitude</span>
            <span class="pillar-metric">Feelings</span>
            <span class="pillar-metric">A/B/C Game</span>
          </div>
        </a>

        <a href="/en/craft/" class="pillar-card animate-on-scroll" data-pillar="oficio">
          <div class="pillar-icon">🎯</div>
          <h3>Craft <span style="font-size:0.75rem;color:var(--text-muted);">→</span></h3>
          <p>Volume and deliberate study. The app measures whether you're executing what you planned — no fooling yourself.</p>
          <div class="pillar-metrics">
            <span class="pillar-metric">Tournaments</span>
            <span class="pillar-metric">Study (h)</span>
            <span class="pillar-metric">Deliberate practice</span>
          </div>
        </a>

        <a href="/en/system/" class="pillar-card animate-on-scroll" data-pillar="sistema">
          <div class="pillar-icon">⚡</div>
          <h3>System <span style="font-size:0.75rem;color:var(--text-muted);">→</span></h3>
          <p>Consistency beats talent. Perfect days, streaks, routine adherence. The Playbook shows whether you're building habits or just reacting.</p>
          <div class="pillar-metrics">
            <span class="pillar-metric">Perfect days</span>
            <span class="pillar-metric">Streak</span>
            <span class="pillar-metric">Adherence</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ========== AI COACH ========== -->
  <section class="section coach-section" id="coach">
    <div class="container">
      <div class="animate-on-scroll">
        <span class="section-label">AI Coach</span>
        <h2 class="section-title">A coach that knows your data, not your excuses.</h2>
        <p class="section-subtitle">
          Claude Opus analyzes your check-ins and cross-references sleep with volume, exercise with tilt, routine with results. Every week, a report no human coach has time to build.
        </p>
      </div>

      <div class="coach-grid">
        <div class="coach-features animate-on-scroll">
          <div class="coach-feature">
            <div class="coach-feature-icon">📊</div>
            <div>
              <h4>Weekly Review</h4>
              <p>4 Pillar scores, what worked, what didn't, and what to do next week. Straight to the point.</p>
            </div>
          </div>
          <div class="coach-feature">
            <div class="coach-feature-icon">📈</div>
            <div>
              <h4>Monthly & Yearly Review</h4>
              <p>Long-term patterns you can't see day to day. Real evolution backed by data, not feelings.</p>
            </div>
          </div>
          <div class="coach-feature">
            <div class="coach-feature-icon">🔬</div>
            <div>
              <h4>Emotional Patterns</h4>
              <p>When do you tilt most? After bad sleep? On days without exercise? The AI finds your triggers in your data.</p>
            </div>
          </div>
          <div class="coach-feature">
            <div class="coach-feature-icon">📚</div>
            <div>
              <h4>Scientific Frameworks</h4>
              <p>Frameworks from Jared Tendler, Tommy Angelo, Yerkes-Dodson, deliberate practice and periodization — automatically applied to your data.</p>
            </div>
          </div>
        </div>

        <div class="coach-preview animate-on-scroll">
          <div class="coach-preview-header">
            <div class="coach-avatar">♠</div>
            <div>
              <div class="coach-preview-name">Playbook Coach</div>
              <div class="coach-preview-label">Claude Opus · Weekly Review</div>
            </div>
          </div>
          <div class="coach-bubble">
            <strong>Solid week.</strong> 847 tournaments across 4 grind days — 80% adherence. Exercise dropped to 2/4 days, which may explain the sleep average dropping from 7.2h to 6.5h...
          </div>
          <div class="coach-bubble">
            I recommend focusing on the <strong>Body Pillar</strong> this week. Tommy Angelo would say: before chasing more volume, make sure your C-game is being eliminated through consistent sleep and exercise.
          </div>
          <div class="coach-scorecard">
            <div class="coach-score">
              <div class="coach-score-value" style="color: var(--pillar-corpo)">7.2</div>
              <div class="coach-score-label">Body</div>
            </div>
            <div class="coach-score">
              <div class="coach-score-value" style="color: var(--pillar-mente)">8.5</div>
              <div class="coach-score-label">Mind</div>
            </div>
            <div class="coach-score">
              <div class="coach-score-value" style="color: var(--pillar-oficio)">8.0</div>
              <div class="coach-score-label">Craft</div>
            </div>
            <div class="coach-score">
              <div class="coach-score-value" style="color: var(--pillar-sistema)">7.8</div>
              <div class="coach-score-label">System</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== HOW IT WORKS ========== -->
  <section class="section" id="how-it-works" style="background: var(--bg-secondary);">
    <div class="container">
      <div class="animate-on-scroll" style="text-align: center;">
        <span class="section-label" style="justify-content: center;">How it works</span>
        <h2 class="section-title">2 minutes a day. The AI does the rest.</h2>
      </div>

      <div class="steps">
        <div class="step animate-on-scroll">
          <div class="step-number">1</div>
          <h3>Daily check-in</h3>
          <p>Log tournaments, sleep, exercise, study and how you felt. Under 2 minutes.</p>
        </div>

        <div class="step animate-on-scroll">
          <div class="step-number">2</div>
          <h3>The AI Coach connects the dots</h3>
          <p>The AI Coach cross-references your data and finds patterns: bad sleep → more tilt? No exercise → less volume? The numbers answer.</p>
        </div>

        <div class="step animate-on-scroll">
          <div class="step-number">3</div>
          <h3>Build your mental foundation</h3>
          <p>Week by week, you stop reacting and start having a method. Routine becomes habit. Habit becomes performance.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" style="background: var(--bg-secondary);">
    <div class="container">
      <div class="animate-on-scroll" style="text-align: center;">
        <span class="section-label" style="justify-content: center;">Plans</span>
        <h2 class="section-title">Start free. Upgrade when it makes sense.</h2>
        <p class="section-subtitle" style="margin: 0 auto;">
          No time limit on the free plan. When you want deeper data and AI, the paid plans are there.
        </p>
        <p style="font-size: 0.8rem; color: var(--text-muted); margin-top: 0.5rem;">Prices in BRL (Brazilian Real) · ~$5/mo Pro · ~$10/mo Elite</p>
      </div>

      <div class="pricing-grid">
        <div class="pricing-tier animate-on-scroll">
          <h3 class="tier-name">Grind</h3>
          <p class="tier-tagline">Everything to start tracking your mental performance. No time limit.</p>
          <div class="tier-price">
            <span class="tier-amount">Free</span>
          </div>
