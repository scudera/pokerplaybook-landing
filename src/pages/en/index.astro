---
import Layout from '../../layouts/Layout.astro';

const title = 'Poker Playbook — Mental Performance for MTT Players';
const description = 'The first AI-powered mental performance platform for poker. Control tilt, build routine and make better decisions. Free to start.';

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'What is Poker Playbook?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'A complete performance system for professional poker players. Combines daily check-in, AI Coach with Claude Opus 4, Mastery system with XP, and detailed analytics of the 4 Pillars (Body, Mind, Craft, System).'
      }
    },
    {
      '@type': 'Question',
      name: 'Is the app free?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The Grind plan is 100% free — no trial period, no credit card required. It includes daily check-in, score, routine, mindset and records. For AI Coach, advanced analytics and custom checklist, there are Pro and Elite plans. All paid plans have a 25% discount on the annual plan.'
      }
    },
    {
      '@type': 'Question',
      name: 'How does the AI Coach work?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "The AI Coach is powered by Claude Opus (Anthropic's frontier AI) and analyzes your check-in data — tournament volume, exercise, sleep, study, feelings during the grind. It generates 5 report types (weekly, monthly, yearly, complete and emotional patterns) using frameworks from Jared Tendler, Tommy Angelo, sports periodization and deliberate practice."
      }
    },
    {
      '@type': 'Question',
      name: 'What are the 4 Pillars?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'The 4 dimensions of professional poker performance: Body (exercise, sleep, breathing), Mind (gratitude, emotional awareness), Craft (grind volume and study hours) and System (consistency and perfect days). Each pillar gets a 0-10 score in your weekly report.'
      }
    },
    {
      '@type': 'Question',
      name: 'What is the Scientist Agent?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'An exclusive Elite plan feature that analyzes your data and proposes hypotheses about what improves your performance. You approve the hypotheses, the agent tests with your real data, and confirmed knowledge feeds your future analyses.'
      }
    },
    {
      '@type': 'Question',
      name: 'Does it work for cash games?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Poker Playbook was built for MTT. Metrics, goals and AI Coach analyses are calibrated for tournaments — tournament volume, buy-in, field, ITM. The mental performance tools (routine, mindset, breathing) work for any format, but the full experience is optimized for MTT grinders.'
      }
    },
    {
      '@type': 'Question',
      name: 'Does this actually work?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "We won't promise your ROI will go up. Poker has variance and results depend on many factors. What the Playbook gives you is a system, data and insights to build a solid mental foundation. The impact on results is a consequence of playing with better preparation — consistently, not by luck."
      }
    },
    {
      '@type': 'Question',
      name: 'Is my data private?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Your data stays in your profile and only you have access. The AI Coach processes your data exclusively to generate your personal analyses. No information is shared with third parties or used to train AI models.'
      }
    },
    {
      '@type': 'Question',
      name: 'Can I use it on mobile?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Poker Playbook is a responsive web app optimized for any browser — desktop, tablet or mobile. No app download needed. Just go to app.pokerplaybook.pro and sign in.'
      }
    },
    {
      '@type': 'Question',
      name: 'Do I need experience to use it?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No. The onboarding sets everything up in 5 simple steps: your goals, weekly schedule, routine, and objectives. The app guides you daily with check-in, checklist, and gratitudes.'
      }
    },
    {
      '@type': 'Question',
      name: 'Can I cancel anytime?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. Cancellation is instant via the Stripe payment portal. No penalty, no commitment, no hassle. Your plan stays active until the end of the paid period.'
      }
    }
  ]
};
---

<Layout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- ========== NAV ========== -->
  <nav class="nav" id="navbar">
    <div class="container nav-inner">
      <a href="/en/" class="nav-logo">
        <img src="/spade-logo.png" class="spade" alt="Poker Playbook" width="20" height="20" /> Poker Playbook
      </a>
      <ul class="nav-links" id="nav-links">
        <li><a href="#pain">The Problem</a></li>
        <li><a href="#method">How It Works</a></li>
        <li><a href="#coach">AI Coach</a></li>
        <li><a href="#pricing">Plans</a></li>
        <li><a href="https://blog.pokerplaybook.pro" target="_blank">Blog</a></li>
        <li><a href="/" class="lang-switch" title="Português">PT</a></li>
        <li><a href="https://app.pokerplaybook.pro" class="nav-cta">Open App →</a></li>
      </ul>
      <button class="nav-mobile-toggle" id="nav-toggle" aria-label="Menu">☰</button>
    </div>
  </nav>

  <!-- ========== HERO ========== -->
  <section class="hero section" id="hero">
    <div class="container">
      <div class="hero-content">
        <h1>
          You know how to play. But do you know <span class="gradient">why you tilted yesterday?</span>
        </h1>

        <p class="hero-sub">
          Solvers don't fix tilt. Trackers don't measure sleep. Coaches aren't there every day.<br />
          There's a missing piece — and it's not technical.
        </p>

        <div class="hero-actions">
          <a href="https://app.pokerplaybook.pro" class="btn-primary">
            Start free →
          </a>
          <a href="#method" class="btn-secondary">
            See how it works ↓
          </a>
        </div>

        <div class="hero-proof">
          <div class="hero-proof-item">
            <span class="icon">✓</span> Free forever
          </div>
          <div class="hero-proof-item">
            <span class="icon">✓</span> No credit card
          </div>
          <div class="hero-proof-item">
            <span class="icon">✓</span> 2 min/day
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== THE PAIN ========== -->
  <section class="section" id="pain" style="background: var(--bg-secondary);">
    <div class="container">
      <div class="animate-on-scroll" style="text-align: center;">
        <span class="section-label" style="justify-content: center;">The problem</span>
        <h2 class="section-title">Sound familiar?</h2>
      </div>

      <div class="pain-stack">
        <div class="pain-card animate-on-scroll">
          <div class="pain-emoji">🛏️</div>
          <p>Slept 5 hours. Grinded 12 anyway. Lost 15 buy-ins and can't tell if it was variance or exhaustion.</p>
        </div>
        <div class="pain-card animate-on-scroll">
          <div class="pain-emoji">🧠</div>
          <p>Tilted on a Sunday Major bubble. Knew you were tilting. Kept playing. Then promised "never again" — for the third time this month.</p>
        </div>
        <div class="pain-card animate-on-scroll">
          <div class="pain-emoji">📊</div>
          <p>You have a tracker, solver, coach. But when it comes to understanding why one week was great and another was a disaster... you open a blank spreadsheet and give up.</p>
        </div>
      </div>

      <p class="section-hook animate-on-scroll">The difference between reacting and having a method fits in 2 minutes a day.</p>
    </div>
  </section>

  <!-- ========== METHOD ========== -->
  <section class="section" id="method">
    <div class="container">
      <div class="animate-on-scroll" style="text-align: center;">
        <span class="section-label" style="justify-content: center;">The method</span>
        <h2 class="section-title">2 minutes. Every day. The AI does the rest.</h2>
        <p class="section-subtitle" style="margin: 0 auto;">
          Daily check-in: how you slept, if you trained, how many tournaments you played, how you felt. That simple.
        </p>
      </div>

      <div class="screenshot-placeholder animate-on-scroll" role="img" aria-label="Poker Playbook daily check-in screenshot">
        <span>📱 Check-in screenshot — coming soon</span>
      </div>

      <p class="section-hook animate-on-scroll">Logging is easy. The hard part is turning notes into insight.</p>
    </div>
  </section>

  <!-- ========== PATTERNS ========== -->
  <section class="section" id="patterns" style="background: var(--bg-secondary);">
    <div class="container">
      <div class="animate-on-scroll" style="text-align: center;">
        <span class="section-label" style="justify-content: center;">Patterns</span>
        <h2 class="section-title">The AI cross-references your data and finds what you can't see.</h2>
      </div>

      <div class="pattern-grid">
        <div class="pattern-card animate-on-scroll">
          <div class="pattern-icon">🛏️→📉</div>
          <h3>Sleep vs. Volume</h3>
          <p>The system discovers if your bad nights are connected to volume drops and increased negative feelings.</p>
        </div>
        <div class="pattern-card animate-on-scroll">
          <div class="pattern-icon">💪→🧠</div>
          <h3>Exercise vs. A-Game</h3>
          <p>Do you play better on training days? The Playbook tests this with your real data.</p>
        </div>
        <div class="pattern-card animate-on-scroll">
          <div class="pattern-icon">📅→🔥</div>
          <h3>Consistency vs. Results</h3>
          <p>How many consecutive perfect days do you need for a positive week? The data answers.</p>
        </div>
      </div>

      <p class="section-hook animate-on-scroll">Who runs this analysis every week, without fail, without bias?</p>
    </div>
  </section>

  <!-- ========== AI COACH ========== -->
  <section class="section coach-section" id="coach">
    <div class="container">
      <div class="animate-on-scroll" style="text-align: center;">
        <span class="section-label" style="justify-content: center;">AI Coach</span>
        <h2 class="section-title">A coach that knows your data, not your excuses.</h2>
        <p class="section-subtitle" style="margin: 0 auto;">
          Claude Opus analyzes your check-ins and cross-references sleep with volume, exercise with tilt, routine with results. Every week, a report no human coach has time to create.
        </p>
      </div>

      <div class="coach-feature-grid">
        <div class="coach-feature animate-on-scroll">
          <div class="coach-feature-icon">📊</div>
          <div>
            <h4>Weekly Review</h4>
            <p>4-Pillar score, what worked, what didn't.</p>
          </div>
        </div>
        <div class="coach-feature animate-on-scroll">
          <div class="coach-feature-icon">📈</div>
          <div>
            <h4>Monthly & Yearly</h4>
            <p>Long-term patterns with data, not gut feeling.</p>
          </div>
        </div>
        <div class="coach-feature animate-on-scroll">
          <div class="coach-feature-icon">🔬</div>
          <div>
            <h4>Emotional Patterns</h4>
            <p>When do you tilt most? The AI finds the triggers.</p>
          </div>
        </div>
        <div class="coach-feature animate-on-scroll">
          <div class="coach-feature-icon">📚</div>
          <div>
            <h4>Science Frameworks</h4>
            <p>Tendler, Angelo, Yerkes-Dodson, deliberate practice.</p>
          </div>
        </div>
      </div>

      <div class="screenshot-placeholder screenshot-landscape animate-on-scroll" role="img" aria-label="AI Coach weekly review screenshot">
        <span>📊 Coach report — coming soon</span>
      </div>

      <p class="section-hook animate-on-scroll">What if the AI didn't just analyze, but proposed hypotheses about what improves YOUR performance?</p>
    </div>
  </section>

  <!-- ========== RESEARCH AGENT ========== -->
  <section class="section" id="scientist" style="background: var(--bg-secondary);">
    <div class="container">
      <div class="animate-on-scroll" style="text-align: center;">
        <span class="section-label" style="justify-content: center;">Scientist</span>
        <h2 class="section-title">
          The Research Agent. <span class="badge-elite">Elite only</span>
        </h2>
        <p class="section-subtitle" style="margin: 0 auto;">
          The AI analyzes your data, spots anomalies and proposes hypotheses: "Does morning exercise improve your afternoon volume?" You approve. It collects data. Tests. And turns the result into permanent knowledge about you.
        </p>
      </div>

      <div class="cientista-flow animate-on-scroll">
        <div class="cientista-step">
          <div class="cientista-step-icon">🔍</div>
          <div class="cientista-step-label">Spots pattern</div>
        </div>
        <div class="cientista-arrow">→</div>
        <div class="cientista-step">
          <div class="cientista-step-icon">🧪</div>
          <div class="cientista-step-label">Proposes hypothesis</div>
        </div>
        <div class="cientista-arrow">→</div>
        <div class="cientista-step">
          <div class="cientista-step-icon">✅</div>
          <div class="cientista-step-label">Confirms or refutes</div>
        </div>
      </div>

      <p class="cientista-stats animate-on-scroll">
        <span data-stat-inline="hypotheses">17</span> hypotheses created ·
        <span data-stat-inline="testing">3</span> being tested now
      </p>
    </div>
  </section>

  <!-- ========== CREDIBILITY ========== -->
  <section class="section" id="credibility">
    <div class="container">
      <div class="animate-on-scroll" style="text-align: center;">
        <span class="section-label" style="justify-content: center;">Credibility</span>
        <h2 class="section-title">Built by someone who lives the grind.</h2>
      </div>

      <blockquote class="founder-quote animate-on-scroll">
        "Created by a professional MTT player who uses the system every day. This isn't theory — it's the method I use to prepare before every session."
      </blockquote>

      <div class="stats-grid animate-on-scroll">
        <div class="stat-item">
          <span class="stat-number" data-stat="checkins">98</span><span class="stat-plus">+</span>
          <span class="stat-label">check-ins logged</span>
        </div>
        <div class="stat-item">
          <span class="stat-number" data-stat="ai-reviews">9</span>
          <span class="stat-label">AI reports generated</span>
        </div>
        <div class="stat-item">
          <span class="stat-number" data-stat="hypotheses">17</span>
          <span class="stat-label">scientific hypotheses</span>
        </div>
        <div class="stat-item">
          <span class="stat-number" data-stat="active-since">Jan 2026</span>
          <span class="stat-label">active since</span>
        </div>
      </div>

      <div class="frameworks-list animate-on-scroll">
        <span class="frameworks-label">Based on:</span>
        <span class="framework-badge">Jared Tendler — The Mental Game of Poker</span>
        <span class="framework-badge">Tommy Angelo — Elements of Poker</span>
        <span class="framework-badge">Sports Periodization</span>
        <span class="framework-badge">Deliberate Practice (Ericsson)</span>
        <span class="framework-badge">Yerkes-Dodson</span>
      </div>

      <p class="tech-stack animate-on-scroll">
        Powered by: Claude Opus (Anthropic) · Stripe · Supabase
      </p>

      <p class="pillar-links-inline animate-on-scroll">
        Explore the 4 Pillars in detail →
        <a href="/en/body/">Body</a> ·
        <a href="/en/mind/">Mind</a> ·
        <a href="/en/craft/">Craft</a> ·
        <a href="/en/system/">System</a>
      </p>

      <!-- TESTIMONIALS: add here when available -->
    </div>
  </section>

  <!-- ========== PRICING ========== -->
  <section class="section" id="pricing" style="background: var(--bg-secondary);">
    <div class="container">
      <div class="animate-on-scroll" style="text-align: center;">
        <span class="section-label" style="justify-content: center;">Plans</span>
        <h2 class="section-title">Start free. Upgrade when it makes sense.</h2>
        <p class="section-subtitle" style="margin: 0 auto;">
          No time limit on the free plan. No surprises.
        </p>
        <p style="font-size: 0.8rem; color: var(--text-muted); margin-top: 0.5rem;">Prices in BRL (Brazilian Real) · ~$5/mo Pro · ~$10/mo Elite</p>
      </div>

      <div class="pricing-grid">
        <div class="pricing-tier animate-on-scroll">
          <h3 class="tier-name">Grind</h3>
          <p class="tier-tagline">Everything to start tracking your mental performance. No time limit.</p>
          <div class="tier-price">
            <span class="tier-amount">Free</span>
          </div>
          <ul class="tier-features">
            <li><span class="check">✓</span> Daily check-in + standard checklist</li>
            <li><span class="check">✓</span> General score, financials, study</li>
            <li><span class="check">✓</span> Routine, flowchart, mindset, breathing</li>
            <li><span class="check">✓</span> Roadmap + milestones</li>
            <li><span class="check">✓</span> Streaks + records</li>
          </ul>
          <a href="https://app.pokerplaybook.pro" class="btn-tier">
            Start free
          </a>
        </div>

        <div class="pricing-tier pricing-tier--featured animate-on-scroll">
          <div class="tier-badge">Recommended</div>
          <h3 class="tier-name">👑 Pro</h3>
          <p class="tier-tagline">Deep data + AI. For those who want to understand their patterns.</p>
          <div class="tier-price">
            <span class="tier-amount">R$29</span>
            <span class="tier-period">/month</span>
          </div>
          <p class="tier-annual">R$349/year (save R$119)</p>
          <ul class="tier-features">
            <li><span class="check">✓</span> Everything in Grind +</li>
            <li><span class="check">✓</span> Full 4-Pillar Dashboard</li>
            <li><span class="check">✓</span> Detailed analytics (check-in, mental tech)</li>
            <li><span class="check">✓</span> Custom checklist</li>
            <li><span class="check">✓</span> Goals + vacation + export</li>
            <li><span class="check">✓</span> Mastery + XP + achievements</li>
            <li><span class="check">✓</span> AI Coach: Weekly, Monthly, Patterns (10/mo)</li>
          </ul>
          <a href="https://app.pokerplaybook.pro" class="btn-tier btn-tier--featured">
            Subscribe Pro
          </a>
        </div>

        <div class="pricing-tier animate-on-scroll">
          <h3 class="tier-name">💎 Elite</h3>
          <p class="tier-tagline">Unlimited AI + Scientist Agent. The complete system.</p>
          <div class="tier-price">
            <span class="tier-amount">R$58</span>
            <span class="tier-period">/month</span>
          </div>
          <p class="tier-annual">R$697/year (save R$251)</p>
          <ul class="tier-features">
            <li><span class="check">✓</span> Everything in Pro +</li>
            <li><span class="check">✓</span> Unlimited AI Coach (+ YTD, Complete)</li>
            <li><span class="check">✓</span> Full Scientist Agent</li>
            <li><span class="check">✓</span> Dynamic metrics</li>
            <li><span class="check">✓</span> Rankings + early access</li>
            <li><span class="check dim">◇</span> Coming soon: AI chat, alerts, correlations</li>
          </ul>
          <a href="https://app.pokerplaybook.pro" class="btn-tier btn-tier--elite">
            Subscribe Elite
          </a>
        </div>
      </div>

      <div class="trust-badges animate-on-scroll">
        <span>🔒 Secure payment via Stripe</span>
        <span class="trust-sep">·</span>
        <span>↩️ Cancel in 1 click, no penalty</span>
        <span class="trust-sep">·</span>
        <span>🛡️ Your data is 100% private</span>
      </div>
    </div>
  </section>

  <!-- ========== FAQ ========== -->
  <section class="section" id="faq">
    <div class="container">
      <div class="animate-on-scroll" style="text-align: center;">
        <span class="section-label" style="justify-content: center;">FAQ</span>
        <h2 class="section-title">Frequently asked questions</h2>
      </div>

      <div class="faq-list">
        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">
            What is Poker Playbook?
            <span class="icon">+</span>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              A complete performance system for professional poker players. Combines daily check-in, AI Coach with Claude Opus 4, Mastery system with XP, and detailed analytics of the 4 Pillars (Body, Mind, Craft, System).
            </div>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">
            Is the app free?
            <span class="icon">+</span>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              The Grind plan is 100% free — no trial period, no credit card required. It includes daily check-in, score, routine, mindset and records. For AI Coach, advanced analytics and custom checklist, there are Pro and Elite plans. All paid plans have a 25% discount on the annual plan.
            </div>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">
            How does the AI Coach work?
            <span class="icon">+</span>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              The AI Coach is powered by Claude Opus (Anthropic's frontier AI) and analyzes your check-in data — tournament volume, exercise, sleep, study, feelings during the grind. It generates 5 report types (weekly, monthly, yearly, complete and emotional patterns) using frameworks from Jared Tendler, Tommy Angelo, sports periodization and deliberate practice.
            </div>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">
            What are the 4 Pillars?
            <span class="icon">+</span>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              The 4 dimensions of professional poker performance: Body (exercise, sleep, breathing), Mind (gratitude, emotional awareness), Craft (grind volume and study hours) and System (consistency and perfect days). Each pillar gets a 0-10 score in your weekly report.
            </div>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">
            What is the Scientist Agent?
            <span class="icon">+</span>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              An exclusive Elite plan feature that analyzes your data and proposes hypotheses about what improves your performance. You approve the hypotheses, the agent tests with your real data, and confirmed knowledge feeds your future analyses.
            </div>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">
            Does it work for cash games?
            <span class="icon">+</span>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              Poker Playbook was built for MTT. Metrics, goals and AI Coach analyses are calibrated for tournaments — tournament volume, buy-in, field, ITM. The mental performance tools (routine, mindset, breathing) work for any format, but the full experience is optimized for MTT grinders.
            </div>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">
            Does this actually work?
            <span class="icon">+</span>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              We won't promise your ROI will go up. Poker has variance and results depend on many factors. What the Playbook gives you is a system, data and insights to build a solid mental foundation. The impact on results is a consequence of playing with better preparation — consistently, not by luck.
            </div>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">
            Is my data private?
            <span class="icon">+</span>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              Yes. Your data stays in your profile and only you have access. The AI Coach processes your data exclusively to generate your personal analyses. No information is shared with third parties or used to train AI models.
            </div>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">
            Can I use it on mobile?
            <span class="icon">+</span>
          </button>
          <div class="faq-answer">
            <div class="faq-answer-inner">
              Yes. Poker Playbook is a responsive web app optimized for any browser — desktop, tablet or mobile. No app download needed. Just go to app.pokerplaybook.pro and sign in.
            </div>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question" aria-expanded="false">
            Do I need experience to use it?
