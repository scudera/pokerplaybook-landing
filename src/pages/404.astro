    <div>
      <div style="font-size: 4rem; margin-bottom: 1rem; color: var(--accent);">♠</div>
      <h1 style="font-size: 2rem; margin-bottom: 0.5rem;">404</h1>
      <p style="color: var(--text-secondary); margin-bottom: 2rem;">Essa página não existe. Assim como fold perfeito — às vezes o melhor é não estar lá.</p>
      <a href="/" class="btn-primary">Voltar ao início →</a>
    </div>
  </div>
</Layout>
