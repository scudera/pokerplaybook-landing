---
interface Props {
  title: string;
  description: string;
  image?: string;
  canonicalURL?: string;
}

const {
  title,
  description,
  image = '/og-default.png',
  canonicalURL = new URL(Astro.url.pathname, Astro.site).href,
} = Astro.props;

const siteName = 'Poker Playbook';

const canonicalPath = Astro.url.pathname;
const isEn = canonicalPath.startsWith('/en');
const ptPath = isEn ? canonicalPath.replace('/en/', '/').replace('/en', '/').replace('/body', '/corpo').replace('/mind', '/mente').replace('/craft', '/oficio').replace('/system', '/sistema') : canonicalPath;
const enPath = isEn ? canonicalPath : canonicalPath === '/' ? '/en/' : `/en${canonicalPath.replace('/corpo', '/body').replace('/mente', '/mind').replace('/oficio', '/craft').replace('/sistema', '/system')}`;
const ptURL = new URL(ptPath, Astro.site).href;
const enURL = new URL(enPath, Astro.site).href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Poker Playbook',
  description: isEn
    ? 'Performance platform for professional MTT poker players. Daily check-in, AI Coach powered by Claude Opus, 4-Pillar Scorecard and mental game techniques.'
    : 'Plataforma de performance para jogadores profissionais de poker MTT. Check-in diário, AI Coach com Claude Opus, Scorecard dos 4 Pilares e técnicas de mental game.',
  url: 'https://pokerplaybook.pro',
  applicationCategory: 'SportsApplication',
  operatingSystem: 'Web',
  offers: [
    {
      '@type': 'Offer',
      name: 'Grind',
      price: '0',
      priceCurrency: 'BRL',
    },
    {
      '@type': 'Offer',
      name: 'Pro',
      price: '29',
      priceCurrency: 'BRL',
      billingIncrement: 'P1M',
    },
    {
      '@type': 'Offer',
      name: 'Elite',
      price: '58',
      priceCurrency: 'BRL',
      billingIncrement: 'P1M',
    },
  ],
  author: {
    '@type': 'Person',
    name: 'Vitor Marguti',
  },
};

const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Poker Playbook',
  url: 'https://pokerplaybook.pro',
  logo: 'https://pokerplaybook.pro/logo.png',
  sameAs: [],
};
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<!-- Primary SEO -->
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />
<meta name="robots" content="index, follow" />
<link rel="sitemap" href="/sitemap-index.xml" />

<!-- Hreflang -->
<link rel="alternate" hreflang="pt-BR" href={ptURL} />
<link rel="alternate" hreflang="en" href={enURL} />
<link rel="alternate" hreflang="x-default" href={ptURL} />

<!-- Favicon -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />

<!-- Locale -->
<meta property="og:locale" content={isEn ? 'en_US' : 'pt_BR'} />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:site_name" content={siteName} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:image" content={new URL(image, Astro.site).href} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={new URL(image, Astro.site).href} />

<!-- JSON-LD -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
<script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />

<!-- Google Analytics 4 -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-7ZRQS4R3GQ"></script>
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-7ZRQS4R3GQ');
</script>

<!-- UTM Propagation: captures UTMs from URL, persists first-touch 30d, propagates to app.pokerplaybook.pro links. Last-touch UTMs override stored, but first_touch_at/url are preserved from the original visit. -->
<script is:inline>
  (function() {
    const STORAGE_KEY = 'pp_utm';
    const TTL_DAYS = 30;
    const APP_HOST = 'app.pokerplaybook.pro';
    const UTM_KEYS = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_content', 'utm_term'];

    const qs = new URLSearchParams(window.location.search);
    const urlUtms = {};
    UTM_KEYS.forEach(k => { const v = qs.get(k); if (v) urlUtms[k] = v; });
    const hasUrlUtms = Object.keys(urlUtms).length > 0;

    let stored = null;
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (raw) {
        const p = JSON.parse(raw);
        const maxAge = TTL_DAYS * 24 * 60 * 60 * 1000;
        if (Date.now() - (p.saved_at || 0) < maxAge) stored = p;
        else localStorage.removeItem(STORAGE_KEY);
      }
    } catch (e) { /* private mode / storage disabled */ }

    // Save first-touch only if nothing valid stored yet.
    if (hasUrlUtms && !stored) {
      try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify({
          utms: urlUtms,
          first_touch_at: new Date().toISOString(),
          first_touch_url: window.location.href,
          saved_at: Date.now(),
        }));
      } catch (e) { /* ignore */ }
    }

    // Effective attribution: URL UTMs override stored UTMs (last-touch),
    // but first_touch_at/url are always preserved from the earliest visit.
    let effective = null;
    if (hasUrlUtms && stored) {
      effective = {
        utms: Object.assign({}, stored.utms, urlUtms),
        first_touch_at: stored.first_touch_at,
        first_touch_url: stored.first_touch_url,
      };
    } else if (hasUrlUtms) {
      effective = {
        utms: urlUtms,
        first_touch_at: new Date().toISOString(),
        first_touch_url: window.location.href,
      };
    } else if (stored) {
      effective = {
        utms: stored.utms,
        first_touch_at: stored.first_touch_at,
        first_touch_url: stored.first_touch_url,
      };
    }
    if (!effective) return;

    function rewrite() {
      document.querySelectorAll('a[href*="' + APP_HOST + '"]').forEach(a => {
        try {
          const u = new URL(a.href);
          if (u.hostname !== APP_HOST) return;
          // Skip if link already has any UTM param (e.g. bio pages).
          if (UTM_KEYS.some(k => u.searchParams.has(k))) return;
          Object.entries(effective.utms).forEach(([k, v]) => u.searchParams.set(k, v));
          if (effective.first_touch_at) u.searchParams.set('first_touch_at', effective.first_touch_at);
          if (effective.first_touch_url) u.searchParams.set('first_touch_url', effective.first_touch_url);
          a.href = u.toString();
        } catch (e) { /* ignore bad URLs */ }
      });
    }

    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', rewrite);
    else rewrite();
  })();
</script>
